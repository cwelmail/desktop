{
  "name": "aeri-desktop",
  "version": "1.0.10",
  "private": true,
  "description": "aeri — Anonymous, private email desktop client",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:next": "next build",
    "build:electron:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64",
    "build:electron:win": "ELECTRON_BUILDER_NSIS_DIR=\"$HOME/Library/Caches/electron-builder/nsis-3.0.4.1/nsis-3.0.4.1-1mx3n\" electron-builder --win --x64",
    "build:mac": "npm run build:next && npm run build:electron:mac",
    "build:win": "npm run build:next && npm run build:electron:win",
    "build": "npm run build:next && npm run build:electron:mac",
    "start": "next start",
    "generate-icon": "node scripts/generate-icon.mjs",
    "generate-dmg-background": "node scripts/generate-dmg-background.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@iconify/react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.8",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "motion": "^12.42.2",
    "next": "16.2.6",
    "react": "^19",
    "react-dom": "^19",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@iconify-json/ph": "^1.2.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "rest.aeri.desktop",
    "productName": "aeri",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "afterPack": "./scripts/after-pack.js",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "public/icon.png",
      "identity": null,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSAppleEventsUsageDescription": "aeri may need Apple Events for system integration.",
        "ElectronTeamID": ""
      }
    },
    "dmg": {
      "title": "aeri",
      "sign": false,
      "writeUpdateInfo": false,
      "background": "build/dmg-background.png",
      "iconSize": 100,
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 180,
          "y": 190
        },
        {
          "x": 480,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}",
      "deleteAppDataOnUninstall": false
    }
  }
}
